{% extends 'layouts/page.njk' %}

{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% from "cph-checkboxes/macro.njk" import appCphCheckboxes %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <a href="/delegation/create/species" class="govuk-back-link">Back</a>

      {% if errors.cphs %}
        {{ govukErrorSummary({
          titleText: "There is a problem",
          errorList: [
            {
              text: errors.cphs,
              href: "#cphs"
            }
          ]
        }) }}
      {% endif %}

      <h1 class="govuk-heading-l govuk-!-margin-bottom-5">{{ heading }}</h1>
      <p class="govuk-body govuk-!-margin-bottom-5">{{ caption }}:</p>

      <form method="post" action="/delegation/create/cphs">
        <input type="hidden" name="crumb" value="{{ crumb }}">
        {{ appCphCheckboxes({
          caption: caption,
          checkboxItems: checkboxItems,
          errorMessage: errors.cphs
        }) }}

        {{ govukButton({
          text: "Continue"
        }) }}
      </form>
    </div>
  </div>
{% endblock %}